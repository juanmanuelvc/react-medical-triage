# LLM — default: local vLLM (Qwen2.5-0.5B-Instruct on CPU)
LLM_MODEL=openai/qwen2.5-0.5B-Instruct
LLM_API_BASE=http://localhost:8080/v1
LLM_API_KEY=

# Cloud provider examples (change LLM_MODEL and set key):
# Anthropic:  LLM_MODEL=anthropic/claude-sonnet-4-6
# Vertex AI:  LLM_MODEL=vertex_ai/gemini-1.5-pro

# Database
DB_PATH=triage.db

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=react-medical-triage
